# udev rule: stable /dev/esp-scale symlink for the ESP32 scale head.
#
# Find your adapter's vendor/product IDs (plug the board in first):
#
#   udevadm info -a -n /dev/ttyUSB0 | grep -E 'idVendor|idProduct' | head -2
#   # or just: lsusb
#
# Then KEEP ONLY the matching rule below — leaving all three active means any
# random CP2102/CH340 dongle you plug in will also claim /dev/esp-scale.
#
# Install:
#   sudo cp deploy/99-esp-scale.rules /etc/udev/rules.d/
#   sudo udevadm control --reload && sudo udevadm trigger
#   ls -l /dev/esp-scale   # should point at ttyUSB0 / ttyACM0

# Silicon Labs CP2102/CP2104 (most common "USB to UART bridge" ESP32 dev boards)
SUBSYSTEM=="tty", ATTRS{idVendor}=="10c4", ATTRS{idProduct}=="ea60", SYMLINK+="esp-scale"

# QinHeng CH340/CH341 (cheap clone boards)
SUBSYSTEM=="tty", ATTRS{idVendor}=="1a86", ATTRS{idProduct}=="7523", SYMLINK+="esp-scale"

# Espressif native USB-Serial/JTAG (ESP32-S3/C3/C6 with direct USB, /dev/ttyACM*)
SUBSYSTEM=="tty", ATTRS{idVendor}=="303a", ATTRS{idProduct}=="1001", SYMLINK+="esp-scale"
